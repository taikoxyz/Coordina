{
  "_schema": "openclaw-config-v1",
  "_description": "OpenClaw configuration for D Squad - Layer 2 Infrastructure Optimization",
  "_created": "2026-03-11",
  "_note": "SECURITY: gatewayToken uses env var substitution. Set GATEWAY_TOKEN in environment before use. Never commit secrets to version control.",
  "team": {
    "name": "D Squad",
    "slug": "team-d-squad",
    "gatewayToken": "${GATEWAY_TOKEN}",
    "namespace": "team-d-squad",
    "workload": [
      "K8s YAML generation",
      "infrastructure code review",
      "agent-to-agent gateway communication",
      "cost-performance optimization"
    ]
  },
  "models": {
    "defaultModel": {
      "id": "google/gemini-3.1-flash-lite-preview",
      "name": "Gemini 3.1 Flash Lite Preview",
      "provider": "google",
      "description": "Cost-effective balanced option for general agent tasks",
      "pricing": {
        "inputPer1M": 0.25,
        "outputPer1M": 1.50,
        "currency": "USD"
      },
      "contextWindow": 1048576,
      "speedTier": "fast",
      "maxTokens": 65536,
      "bestFor": [
        "general sub-agent tasks",
        "agent coordination",
        "mixed workloads",
        "cost-sensitive operations"
      ],
      "parameters": {
        "temperature": 0.7,
        "topP": 0.95,
        "responseFormat": "text"
      }
    },
    "fastModel": {
      "id": "google/gemini-3.1-flash-lite-preview",
      "name": "Gemini 3.1 Flash Lite Preview",
      "provider": "google",
      "description": "High-throughput model for heartbeat checks and simple API calls",
      "pricing": {
        "inputPer1M": 0.25,
        "outputPer1M": 1.50,
        "currency": "USD"
      },
      "contextWindow": 1048576,
      "speedTier": "fast",
      "maxTokens": 65536,
      "bestFor": [
        "heartbeat checks",
        "health checks",
        "status polling",
        "simple API calls",
        "high-frequency tasks"
      ],
      "parameters": {
        "temperature": 0.3,
        "maxTokens": 256,
        "responseFormat": "text"
      }
    },
    "codeModel": {
      "id": "openai/gpt-5.3-codex",
      "name": "GPT-5.3 Codex",
      "provider": "openai",
      "description": "State-of-the-art agentic coding model for infrastructure code generation",
      "pricing": {
        "inputPer1M": 1.75,
        "outputPer1M": 14.00,
        "currency": "USD"
      },
      "contextWindow": 400000,
      "speedTier": "medium",
      "maxTokens": 128000,
      "bestFor": [
        "K8s YAML generation",
        "Dockerfile creation",
        "Terraform configuration",
        "infrastructure code review",
        "multi-file orchestration",
        "complex refactoring"
      ],
      "parameters": {
        "temperature": 0.2,
        "responseFormat": "text",
        "structuredOutputs": true
      },
      "metrics": {
        "sweBenchPro": "57.7%",
        "terminalBench": "Strong"
      }
    },
    "reasoningModel": {
      "id": "openai/gpt-5.4",
      "name": "GPT-5.4",
      "provider": "openai",
      "description": "High-quality reasoning for complex coordination decisions",
      "pricing": {
        "inputPer1M": 2.50,
        "outputPer1M": 15.00,
        "currency": "USD"
      },
      "contextWindow": 1050000,
      "speedTier": "medium",
      "maxTokens": 128000,
      "bestFor": [
        "complex coordination decisions",
        "multi-step problem solving",
        "strategy planning",
        "high-context reasoning",
        "document synthesis"
      ],
      "parameters": {
        "temperature": 0.5,
        "responseFormat": "text",
        "reasoning": true
      }
    },
    "alternatives": {
      "ultraFast": {
        "id": "inception/mercury-2",
        "name": "Mercury 2",
        "description": "Diffusion LLM with >1000 tokens/sec for extreme latency requirements",
        "pricing": { "inputPer1M": 0.25, "outputPer1M": 0.75 }
      },
      "budgetCode": {
        "id": "qwen/qwen3.5-plus-02-15",
        "name": "Qwen3.5 Plus",
        "description": "Cost-effective code generation at 10x lower price",
        "pricing": { "inputPer1M": 0.26, "outputPer1M": 1.56 }
      },
      "premiumReasoning": {
        "id": "anthropic/claude-opus-4.6",
        "name": "Claude Opus 4.6",
        "description": "Maximum reasoning capability for critical decisions",
        "pricing": { "inputPer1M": 5.00, "outputPer1M": 25.00 }
      }
    }
  },
  "gateway": {
    "port": 18789,
    "host": "0.0.0.0",
    "enableHealthCheck": true,
    "healthCheckPath": "/health",
    "timeout": {
      "request": 300000,
      "idle": 120000
    },
    "cors": {
      "enabled": true,
      "origins": ["*"]
    },
    "rateLimit": {
      "enabled": true,
      "requestsPerMinute": 1000
    }
  },
  "memory": {
    "maxContextTokens": 1050000,
    "summarizeThreshold": 800000,
    "chunkSize": 4096,
    "chunkOverlap": 512
  },
  "heartbeat": {
    "enabled": true,
    "intervalMs": 30000,
    "timeoutMs": 5000,
    "retries": 3,
    "useFastModel": true
  },
  "agentCoordination": {
    "maxConcurrentAgents": 10,
    "taskTimeoutMs": 600000,
    "enableSubagentSpawning": true,
    "autoAnnounceResults": true,
    "pushBasedCompletion": true
  },
  "costOptimization": {
    "enableCostTracking": true,
    "budgetAlerts": {
      "daily": 100,
      "weekly": 500,
      "monthly": 2000
    },
    "fallbackModels": {
      "enabled": true,
      "onRateLimit": "google/gemini-3.1-flash-lite-preview",
      "onError": "qwen/qwen3.5-flash-02-23"
    }
  },
  "logging": {
    "level": "info",
    "includeModelCalls": true,
    "includeTokenCounts": true,
    "includeLatencyMetrics": true
  },
  "openrouter": {
    "baseUrl": "https://openrouter.ai/api/v1",
    "providerRouting": {
      "strategy": "lowest-latency",
      "fallbacksEnabled": true,
      "excludeModerated": false
    },
    "headers": {
      "HTTP-Referer": "https://d-squad.ai",
      "X-Title": "D Squad OpenClaw Agents"
    }
  }
}
