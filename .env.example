# Google OAuth2 credentials for GCP + Workspace auth
# Create a "Desktop app" OAuth2 client at https://console.cloud.google.com/apis/credentials
# Add redirect URIs:
#   http://localhost:3000/api/auth/gcp/callback
#   http://localhost:3000/api/auth/workspace/callback
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# Override redirect base if running on a non-standard port (default: http://localhost:3000)
# GOOGLE_REDIRECT_BASE=http://localhost:3000
